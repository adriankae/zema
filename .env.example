# Zema Docker Compose environment.
# Copy this file to .env, fill in real values, and keep .env private.

# Keep this stable across updates. Docker Compose uses it to name containers,
# networks, and volumes. Changing it creates a new empty database volume.
COMPOSE_PROJECT_NAME=zema

# Browser address for the dashboard.
# 127.0.0.1 means "only this computer" and is the safest default.
# Use 0.0.0.0 only if you intentionally want other devices on your network to reach Zema.
ZEMA_HOST_BIND=127.0.0.1
ZEMA_PORT=28173

# Local database port. Most users should leave this local-only.
ZEMA_POSTGRES_HOST_BIND=127.0.0.1
ZEMA_POSTGRES_PORT=15432

# Timezone used for morning/evening due slots and Telegram reminders.
CZM_API_KEY=
CZM_TIMEZONE=Europe/Berlin

# Optional Telegram bot settings.
ZEMA_TELEGRAM_BOT_TOKEN=
ZEMA_TELEGRAM_ALLOWED_CHAT_IDS=
ZEMA_TELEGRAM_ALLOWED_USER_IDS=
ZEMA_TELEGRAM_ALLOW_WRITES=true
ZEMA_TELEGRAM_ALLOW_ADHERENCE_REBUILD=false
